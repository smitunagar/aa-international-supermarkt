# ── Shopify Storefront API ────────────────────────────────────────────────────
# Your Shopify store domain (no https://)
# Example: my-store.myshopify.com
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# Public Storefront API access token
# Create one in: Shopify Admin → Settings → Apps → Develop apps → Storefront API
NEXT_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=your-public-storefront-access-token

# ── Optional: Shopify Admin API (for server-side operations) ──────────────────
# Only needed if you plan to use webhooks, order management, etc.
# SHOPIFY_ADMIN_API_TOKEN=shpat_xxxxxxxxxxxxx
# SHOPIFY_WEBHOOK_SECRET=your-webhook-secret

# ── Site Settings ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://your-domain.de
